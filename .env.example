# OpenWeather
OPENWEATHER_API_KEY=your_openweather_api_key
WEATHER_LAT=37.338207
WEATHER_LON=-121.886330
WEATHER_CITY=San Jose
NEXT_PUBLIC_WEATHER_CITY=San Jose

# Google Calendar (Service Account JSON file in project root)
GOOGLE_CALENDAR_ID=your.email@gmail.com
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=jarvis-command-center-XXXXX.json

# User greeting (client-visible)
NEXT_PUBLIC_USER_NAME=Andrei

# Anthropic (server-only — AI briefing + voice ask)
ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-6
# BRIEFING_TZ=America/Los_Angeles

# Gmail (OAuth — personal inbox; NOT the Calendar service account)
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GMAIL_REFRESH_TOKEN=...   # node scripts/gmail-oauth.mjs (Gmail + Tasks scopes)

# Night mode schedule (client — auto day/night toggle)
# NEXT_PUBLIC_NIGHT_START_HOUR=23
# NEXT_PUBLIC_NIGHT_END_HOUR=7
# NEXT_PUBLIC_NIGHT_TZ=America/Los_Angeles

# Lifecycle: shutdown server when browser tab closes (default on in production)
# JARVIS_LIFECYCLE_SHUTDOWN=1

# ElevenLabs (server-only — cloned voice TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_cloned_voice_id

# Finnhub (optional — SV ticker live quotes)
# FINNHUB_API_KEY=your_finnhub_api_key

# YouTube (server-only — audiobooks library)
YOUTUBE_API_KEY=your_youtube_data_api_key
YOUTUBE_CHANNEL_ID=UCY-ekT04DX2bQhzYvm2y5Lw
