{
  "name": "jarvis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:clean": "node scripts/dev-clean.mjs",
    "build": "next build",
    "start": "next start -p 3001",
    "kiosk": "npm run build && npm start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "launcher:build": "powershell -NoProfile -ExecutionPolicy Bypass -File launcher/build-exe.ps1",
    "launcher:shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File launcher/create-shortcut.ps1"
  },
  "dependencies": {
    "framer-motion": "^12.16.0",
    "googleapis": "^148.0.0",
    "leaflet": "^1.9.4",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "satellite.js": "^7.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
